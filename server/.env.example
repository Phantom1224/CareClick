# App (server settings)
PORT=5000 # Server port

# Database (MongoDB connection)
MONGO_URI=mongodb://127.0.0.1:27017/careclick # Local MongoDB URI
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8 # Optional DNS resolvers (comma-separated)

# Auth (tokens, OTP, cookies)
JWT_SECRET=replace-with-a-strong-secret # JWT signing secret
OTP_EXPIRES_MINUTES=10 # OTP validity window (minutes)
AUTH_COOKIE_NAME=careclick_auth # Auth cookie name
AUTH_COOKIE_DAYS=1 # Auth cookie lifetime (days)

# Email (SMTP credentials)
GMAIL_USER=your-gmail-address@gmail.com # Sender Gmail address
GMAIL_APP_PASSWORD=your-google-app-password # Gmail app password

# MongoDB reference URIs (for convenience)
# Local:  mongodb://127.0.0.1:27017/careclick
# Online: mongodb+srv://<db-username>:<db-password>@backenddb.xrko8as.mongodb.net/careclick?retryWrites=true&w=majority
